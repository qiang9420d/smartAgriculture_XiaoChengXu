page {
  padding: 0;
  margin: 0;
  box-sizing: border-box;
  background-color: #F3F3F3;
}

.page {
  padding: 30rpx;
  height: 80vh;
  box-sizing: border-box;
}

.content {
  margin-top: 200rpx;
  text-align: center;
  font-size: 32rpx;
}

.page-content {
  background-color: #F3F3F3;
  height: 100vh;
  margin-top: 20rpx; /* 这里改成 rpx */
  padding-bottom: 40rpx;
}

/* 设备卡片 真机稳定立体 */
.card-list {
  background: red;
  margin: 20rpx;
  border-radius: 16rpx;
  height: auto;
  padding: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  background: linear-gradient(180deg, #ffffff 0%, #ffffff 100%);
  transition: all 0.2s ease;
  box-sizing: border-box;
}

/* 点击按压立体效果 */
.card-list:active {
  transform: translateY(4rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #030303;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-subtitle {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #0e0d0d;
}

/* 横向分割线 */
.line {
  width: 100%;
  height: 2rpx;
  background: hsl(66, 51%, 39%);
  margin: 20rpx 0;
}

/* 在线角标 */
.onlineBadge_off {
  --td-badge-bg-color: red;
  --td-badge-basic-height: 45rpx;
}
/* 在线角标 */
.onlineBadge_on {
  --td-badge-bg-color: green;
  --td-badge-basic-height: 45rpx;
}

/* 图标 + 文字 横向布局（真机永远居中） */
.icon-text-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 0rpx;
}

.icon-text-row .text {
  font-size: 24rpx;
  color: #666;
}
.col-middle {
  height: 120rpx;
  display: flex;
  align-items: center; /* 垂直居中 */
  align-content: center;
  justify-content: flex-end;
}
.flex-right {
  display: flex !important;
  width: 100%;       /* 必须占满宽度 */
  justify-content: flex-end;
}
.custom-color {
  --td-switch-checked-color: #00a870;
}
.alarm-breath-box {
  /* 报警呼吸动画 */
  animation: alarmBreath 1.2s infinite alternate ease-in-out;
}
/* 核心：边框 + 阴影同步呼吸 */
@keyframes alarmBreath {
  0% {
    border-color: #ff0000;
    box-shadow: 0 0 10rpx 2rpx rgba(255, 0, 0, 0.4);
  }
  100% {
    border-color: #ff4d4f;
    box-shadow: 0 0 25rpx 8rpx rgba(255, 0, 0, 0.8);
  }
}