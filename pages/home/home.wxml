<!--pages/home/home.wxml-->
<navbar title="首页" showAdd="{{true}}" bgColor="#1677ff" titleColor="#fff" showBack="{{false}}" showHome="{{false}}"></navbar>
<!-- 页面内容要加padding-top，避免被导航栏遮挡 -->

<view class="page-content" style="padding-top:{{navBarHeight}}px">
  <t-tabs defaultValue="{{activeTab}}" value="{{activeTab}}" bind:change="onTabsChange"  t-class="custom-tabs">
    <t-tab-panel label="全部" value="0" />
    <t-tab-panel label="开关" value="1" />
    <t-tab-panel label="放风机" value="2" />
    <t-tab-panel label="环境监测" value="3" />
    <t-tab-panel label="卷帘机" value="4" /> 
  </t-tabs>
  <view >
    <view wx:if="{{DevList.length === 0}}" style="margin-top: 40%;">
      <t-empty icon="folder" description="暂无设备" />
    </view>

      <!-- 循环渲染数组 -->
 
    <view wx:for="{{DevList}}" 
      wx:key="id"  class="card-list {{item.Alarm ? 'alarm-breath-box' : ''}} " >
       
       
      <t-row >
        <t-col span="16"  
          bindtap="EquipmentDetails" 
          data-index="{{index}}"  
          data-item="{{item}}">
          <view class="card-title">{{item.devName}}</view>
           <view class="card-subtitle" wx:if="{{item.devType === '1'}}">
            开关设备
           </view>  
          <view class="card-subtitle" wx:elif="{{item.devType === '2'}}">
            放风机
          </view>
          <view class="card-subtitle" wx:elif="{{item.devType === '3'}}">
            环境监测
          </view>
          <view class="card-subtitle" wx:elif="{{item.devType === '4'}}">
            卷帘机
          </view>
          <view class="card-subtitle">{{item.devUuid}}</view>
        </t-col> 
        <t-col span="6" style="text-align: right;">
         
             <view  class="col-middle" catch:tap="onSwitchChange">
               <!-- <view class="custom-color"   >
                 <t-switch  value="{{item.switchState}}" data-id="{{item.id}}"  label="{{['开', '关']}}"  slot="note"  />
              </view> -->
            

            </view> 
       
        </t-col>
        
        <t-col span="1" style="text-align: right;">
          <t-badge 
            count="{{ item.isOnline ? '在线' : '离线' }}" 
            offset="{{ [0,-10] }}"   
            class="{{ item.isOnline ? 'onlineBadge_on' : 'onlineBadge_off' }}"
            ariaRole="button" 
            shape="triangle-right">
            <view  >
              <t-button  shape="square" style="background-color: transparent;"/>
            </view> 
          </t-badge>
        </t-col>
      </t-row>
      <t-row wx:if="{{item.devType === '2'}}">
        <t-col span="8"  > 
           <view style="margin-top: 10rpx;">
            <t-tag class="margin-16" variant="outline" theme="warning">模式：{{ item.workingMode === 4 ? '手动' : item.workingMode === 5 ? '自动' : '未知' }}
</t-tag>
           </view>
        </t-col>
        <t-col span="8"  > 
           <view style="margin-top: 10rpx;">
            <t-tag class="margin-16" variant="outline" theme="warning">温度：{{item.temperature}}℃</t-tag>
           </view>
        </t-col>
        <t-col span="8"  > 
           <view style="margin-top: 10rpx;">
            <t-tag class="margin-16" variant="outline" theme="warning">开度：{{item.openDegree}} CM</t-tag>
           </view>
        </t-col>
      </t-row>
      <t-row >
        <t-col span="24"  > 
           <view class="line"></view>
        </t-col>
      </t-row>
      <t-row>
        <t-col span="11"  >
          <view class="icon-text-row" catch:tap="onRecharge" data-item="{{item}}" >
            <t-icon name="history" size="15" color="#666" />
            <text class="text">到期日期：{{item.expirationTime}}</text>
          </view>
        </t-col>
        <t-col span="1"  >
         
        </t-col>
        <t-col span="8"  >
          <view  wx:if="{{item.Alarm}}" class="icon-text-row">
            <t-tag variant="light" theme="danger">报警</t-tag>
            <!-- <t-tag wx:if="{{item.AlarmType === '0'}}" variant="light" theme="danger">高温报警</t-tag>
            <t-tag wx:if="{{item.AlarmType === '1'}}" variant="light" theme="danger">低温报警</t-tag>  -->
          </view>
        </t-col>
        <t-col span="4"  >
          <view class="icon-text-row" catch:tap="onSetting" data-item="{{item}}" >
            <t-icon name="setting-1" size="20" color="#666" />
            <text class="text">设置</text>
          </view>
        </t-col>
      </t-row>
 
    </view>
 
  </view>
 
  <t-row>
 
</t-row>
 
</view>

