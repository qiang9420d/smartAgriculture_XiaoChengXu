/* 图表容器必须设置宽高，否则不显示！*/
.chart-container {
  width: 100%;
  height: 400rpx;
}
 .chart-box {
  margin-top: 200rpx;
  width: 100%;
  height: 800rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.08);
  box-sizing: border-box; 
}
 
ec-canvas {
  width: 100%;
  height: 100%;
}  
.time-btn-wrap {
  display: flex;
  flex-direction: row;
  gap: 12rpx; /* 按钮之间的间距 */
  padding: 20rpx 16rpx;
}
/* 按钮基础样式，均分宽度 */
.time-btn {
  height: 70rpx;
  flex: 1;
  font-size: 26rpx;
  border-radius: 8rpx;
  /* 默认未选中 */
  background: #f5f5f5;
  color: #666;
  border: 1rpx solid #eee;
  padding: 15rpx;
}
/* 选中激活样式（高亮） */
.time-btn-active {
  background: #409EFF;
  color: #fff;
  border: 1rpx solid #409EFF;
}
/* 清除小程序button默认灰色边框 */
button::after {
  border: none;
}