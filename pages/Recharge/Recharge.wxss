.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
  color: #333;
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  font-size: 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.label {
  color: #666;
}

.value {
  color: #333;
}

.expire {
  color: #faad14;
  font-weight: 500;
}

/* 金额 + 按钮 同一行 */
.pay-row {
  position: fixed;
  left: 0rpx;
  bottom: 100rpx;
  width: 100%;
  background: #fff;
  padding: 20rpx 30rpx;
  box-sizing: border-box;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.price-info {
  font-size: 28rpx;
  color: #333;
}

.price {
  font-size: 36rpx;
  color: #fa412d;
  font-weight: bold;
  margin-left: 8rpx;
}

.pay-btn {
  width: 220rpx !important;
  border-radius: 50rpx !important;
}